<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@android:color/white">

    <!-- Header with title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Weekly Schedule"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Empty state message -->
    <TextView
        android:id="@+id/noClassesText"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="@android:color/darker_gray"
        android:text="No classes scheduled for this week"
        android:visibility="gone" />

    <!-- Calendar grid container -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="horizontal"
        android:id="@+id/calendarScrollView">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:id="@+id/calendarContainer">

            <!-- Time slot column (left) -->
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/grid_border">

                <!-- Time header placeholder -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@android:color/lighter_gray" />

                <!-- Time slots -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:id="@+id/timeSlotsList" />
            </LinearLayout>

            <!-- Day columns container -->
            <LinearLayout
                android:id="@+id/dayColumnsContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        style="?attr/progressBarStyle" />

    <!-- Error message -->
    <TextView
        android:id="@+id/errorText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@android:color/holo_red_dark"
        android:padding="12dp"
        android:visibility="gone"
        android:textSize="14sp" />
</LinearLayout>
