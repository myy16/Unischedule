<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Header with title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Weekly Schedule"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/black" />

            <Button
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Legend row -->
        <LinearLayout
            android:id="@+id/calendarLegend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">
            
            <View android:layout_width="16dp" android:layout_height="16dp" android:background="#C8E6C9" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Available" android:textColor="@android:color/darker_gray" android:layout_marginEnd="16dp" />

            <View android:layout_width="16dp" android:layout_height="16dp" android:background="#FFCDD2" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Busy" android:textColor="@android:color/darker_gray" android:layout_marginEnd="16dp"/>

            <View android:layout_width="16dp" android:layout_height="16dp" android:background="#BBDEFB" android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Your Course" android:textColor="@android:color/darker_gray" />
        </LinearLayout>

        <!-- Calendar grid -->
        <HorizontalScrollView
            android:id="@+id/calendarScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TableLayout
                android:id="@+id/calendarTable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:stretchColumns="1,2,3,4,5"
                android:background="@drawable/grid_border">
                <!-- Rows will be populated programmatically -->
            </TableLayout>
            
        </HorizontalScrollView>

        <!-- Empty state message -->
        <TextView
            android:id="@+id/noClassesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="@android:color/darker_gray"
            android:text="No classes scheduled for this week"
            android:visibility="gone"
            android:layout_marginTop="32dp"/>

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/loadingProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            style="?attr/progressBarStyle"
            android:layout_marginTop="32dp"/>

        <!-- Error message -->
        <TextView
            android:id="@+id/errorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/holo_red_dark"
            android:padding="12dp"
            android:visibility="gone"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
